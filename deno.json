{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages",
    "./examples/www",
    "./examples/fullstack"
  ],
  "tasks": {
    "dev:fullstack": "deno run -A --watch examples/fullstack/dev.ts",
    "build:fullstack": "deno run -A examples/fullstack/dev.ts build",
    "start:fullstack": "deno run -A examples/fullstack/dist/compiled-entry.js",
    "dev:www": "deno run -A --watch examples/www/dev.ts",
    "build:www": "deno run -A examples/www/dev.ts build",
    "start:www": "deno run -A examples/www/dist/compiled-entry.js",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/core/mod.ts packages/dev/mod.ts",
    "test": "deno test -A --no-check"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    },
    "exclude": [
      "**/node_modules",
      "**/_fresh",
      "**/.git"
    ]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "exclude": [
      "**/node_modules",
      "**/_fresh"
    ]
  },
  "imports": {
    "@preact/signals": "npm:@preact/signals@^2.8.2",
    "react": "npm:preact/compat",
    "react-dom": "npm:preact/compat",
    "react/jsx-runtime": "npm:preact/jsx-runtime",
    "react/jsx-dev-runtime": "npm:preact/jsx-dev-runtime"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "preact"
  }
}

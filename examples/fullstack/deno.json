{
  "name": "@howl/fullstack",
  "version": "0.0.0",
  "exports": "./server/main.ts",
  "tasks": {
    "dev": "deno run -A --env-file='../../.env' --watch --watch-exclude=dist/,node_modules/ dev.ts"
  },
  "imports": {
    "@hushkey/howl": "../../packages/howl/core/mod.ts",
    "@hushkey/howl/client": "../../packages/howl/core/client.ts",
    "@hushkey/howl/api": "../../packages/howl/api/mod.ts",
    "@hushkey/howl/dev": "../../packages/howl/dev/mod.ts",
    "@hushkey/howl/plugins": "../../packages/howl/plugins/mod.ts",
    "@hushkey/howl/runtime": "../../packages/howl/core/runtime/shared.ts",
    "@std/path": "jsr:@std/path@^1.0.0",
    "preact": "npm:preact@^10.25.0",
    "preact/hooks": "npm:preact@^10.25.0/hooks",
    "preact/jsx-runtime": "npm:preact@^10.25.0/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10.25.0/jsx-dev-runtime",
    "sonner": "npm:sonner@^2.0.7",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "zod": "npm:zod@4.3.6",
    "daisyui": "npm:daisyui@5.5.18",
    "ioredis": "npm:ioredis@^5.10.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}

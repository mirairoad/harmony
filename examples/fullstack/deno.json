{
  "name": "@howl/fullstack",
  "version": "0.0.0",
  "exports": "./server/main.ts",
  "imports": {
    "@hushkey/howl": "../../packages/core/mod.ts",
    "@hushkey/howl/api": "../../packages/api/mod.ts",
    "@hushkey/howl/dev": "../../packages/dev/mod.ts",
    "@hushkey/howl/plugins": "../../packages/plugins/mod.ts",
    "@hushkey/howl/runtime": "../../packages/core/runtime/shared.ts",
    "@std/path": "jsr:@std/path@^1.0.0",
    "preact": "npm:preact@^10.25.0",
    "preact/hooks": "npm:preact@^10.25.0/hooks",
    "preact/jsx-runtime": "npm:preact@^10.25.0/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10.25.0/jsx-dev-runtime",
    "react": "npm:preact@^10.25.0/compat",
    "react-dom": "npm:preact@^10.25.0/compat",
    "react/jsx-runtime": "npm:preact@^10.25.0/jsx-runtime",
    "react-dom/server": "npm:preact@^10.25.0/compat",
    "react-hot-toast": "npm:react-hot-toast@^2.6.0",
    "@radix-ui/react-tooltip": "npm:@radix-ui/react-tooltip@^1.2.8",
    "sonner": "npm:sonner@^2.0.7",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "zod": "npm:zod@4.3.6",
    "daisyui": "npm:daisyui@5.5.18",
    "ioredis": "npm:ioredis@^5.10.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
